# MySQL (local, no Docker)
DB_DSN=mysql:host=127.0.0.1;port=3306;dbname=yii2api
DB_USER=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

# Demo user password for seeders (required for yii seed/*)
# Set locally in .env — never commit real value
DEMO_USER_PASSWORD=

# API base URL for Photo::getUrl() absolute links (optional)
APP_BASE_URL=http://localhost:8080
